<% if Current.user %>
  <% if Current.organization %>
    <div style="padding: 20px; background: #f5f5f5; border-radius: 8px; margin-bottom: 20px;">
      <% if Current.organization[:logo_url].present? %>
        <img src="<%= Current.organization[:logo_url] %>" alt="<%= Current.organization[:display_name] %> logo" style="max-height: 60px; margin-bottom: 10px;">
      <% end %>
      <h2><%= Current.organization[:display_name] %></h2>
    </div>
  <% end %>
  <%= button_to "Logout", "/auth/logout", method: :get, data: { turbo: false } %>
<% else %>
  <% if params[:org_name].present? %>
    <%= button_to "Login", "/auth/auth0?organization=#{params[:org_name]}", method: :post, data: { turbo: false } %>
  <% else %>
    <%= button_to "Login", "/auth/auth0", method: :post, data: { turbo: false } %>
  <% end %>
<% end %>
